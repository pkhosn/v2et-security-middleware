# V2ET Security Middleware 环境变量配置

# 服务端口
PORT=3001

# V2Board 后端地址（必填）
BACKEND_DOMAIN=https://cs.xn--6kru7hpswi10b.com

# V2Board 后台管理路径（必填，通常是 admin 或你自定义的路径）
ADMIN_API_PREFIX=admin

# V2Board 管理员账号（必填）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_password

# 分销商后台访问密码（可选，不设置则无需验证）
DISTRIBUTOR_ACCESS_PASSWORD=

# 邮件服务配置（可选）
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_SECURE=true
# MAIL_USER=your@gmail.com
# MAIL_PASS=your_password
