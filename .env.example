# V2ET Security Middleware 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# 服务端口
PORT=3001

# V2Board 后端地址（必填）
# 示例：BACKEND_DOMAIN=https://your-v2board.com
BACKEND_DOMAIN=

# V2Board 后台管理路径（必填）
# 示例：ADMIN_API_PREFIX=admin
ADMIN_API_PREFIX=

# V2Board 管理员账号（必填）
ADMIN_EMAIL=
ADMIN_PASSWORD=

# 分销商后台访问密码（可选）
DISTRIBUTOR_ACCESS_PASSWORD=
